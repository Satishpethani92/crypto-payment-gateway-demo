# Payment Gateway base URL
# Local:  http://localhost:3006
# Beta:   https://betapg.icotokens.net
GATEWAY_BASE_URL=https://betapg.icotokens.net

# Swagger documentation
SWAGGER_URL=https://betapg.icotokens.net/api-docs/

# Merchant API credentials — from gateway admin: Settings → Service API
# Use the PLAIN (decrypted) API secret for HMAC signing
GATEWAY_API_KEY=your-api-key-here
GATEWAY_API_SECRET=your-api-secret-here

# Merchant UUID (from gateway admin / merchant profile)
MERCHANT_ID=your-merchant-uuid-here

# Demo store settings
DEMO_PORT=4000
DEMO_STORE_URL=http://localhost:4000
DEMO_STORE_NAME=Demo Merchant Store

# Payment page URL (gateway frontend — where customers pay)
PAYMENT_PAGE_URL=http://localhost:3000
